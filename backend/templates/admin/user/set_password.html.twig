<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pivní Konto - Změna hesla</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #1f2937; color: #f9fafb; display: flex; justify-content: center; align-items: center; min-height: 100vh; padding: 1rem; }
        .box { background: #374151; padding: 2rem; border-radius: 12px; width: 100%; max-width: 480px; box-shadow: 0 4px 24px rgba(0,0,0,0.3); }
        h1 { text-align: center; margin-bottom: 1rem; font-size: 1.5rem; color: #f59e0b; }
        .user-info { background: #1f2937; padding: 0.75rem 1rem; border-radius: 8px; margin-bottom: 1.25rem; font-size: 0.9rem; color: #d1d5db; }
        .user-info strong { color: #f9fafb; }
        .alert { padding: 0.75rem; border-radius: 8px; margin-bottom: 1rem; text-align: center; font-size: 0.9rem; }
        .alert-success { background: #14532d; color: #bbf7d0; }
        .alert-danger { background: #991b1b; color: #fecaca; }
        label { display: block; margin-bottom: 0.25rem; font-size: 0.875rem; color: #9ca3af; }
        input { width: 100%; padding: 0.75rem; border: 1px solid #4b5563; border-radius: 8px; background: #1f2937; color: #f9fafb; font-size: 1rem; margin-bottom: 1rem; }
        input:focus { outline: none; border-color: #f59e0b; }
        .hint { font-size: 0.8rem; color: #9ca3af; margin-top: -0.75rem; margin-bottom: 1rem; }
        .actions { display: flex; gap: 0.5rem; }
        .btn { flex: 1; padding: 0.75rem; border: none; border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer; text-align: center; text-decoration: none; display: inline-block; }
        .btn-primary { background: #f59e0b; color: #1f2937; }
        .btn-primary:hover { background: #d97706; }
        .btn-secondary { background: #4b5563; color: #f9fafb; }
        .btn-secondary:hover { background: #6b7280; }
    </style>
</head>
<body>
    <div class="box">
        <h1>Změna hesla</h1>

        <div class="user-info">
            <div><strong>Uživatel:</strong> {{ user.name }}</div>
            <div><strong>Email:</strong> {{ user.email }}</div>
        </div>

        {% for label, messages in app.flashes(['success', 'danger']) %}
            {% for message in messages %}
                <div class="alert alert-{{ label }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <form method="post" autocomplete="off">
            <input type="hidden" name="_token" value="{{ csrf_token('set_password_' ~ user.id) }}">

            <label for="new_password">Nové heslo</label>
            <input
                type="password"
                id="new_password"
                name="new_password"
                minlength="6"
                required
                autocomplete="new-password"
                autofocus
            >
            <div class="hint">Minimálně 6 znaků.</div>

            <label for="new_password_repeat">Heslo znovu</label>
            <input
                type="password"
                id="new_password_repeat"
                name="new_password_repeat"
                minlength="6"
                required
                autocomplete="new-password"
            >

            <div class="actions">
                <a href="{{ back_url }}" class="btn btn-secondary">Zpět</a>
                <button type="submit" class="btn btn-primary">Uložit heslo</button>
            </div>
        </form>
    </div>
</body>
</html>
